{
  "version": 2,
  "name": "sigam-tools",
  "routes": [
    {
      "src": "/movimiento",
      "dest": "/movimiento/index.html"
    },
    {
      "src": "/movimiento/(.*)",
      "dest": "/movimiento/index.html"
    },
    {
      "src": "/checkpoint",
      "dest": "/checkpoint/index.html"
    },
    {
      "src": "/checkpoint/",
      "dest": "/checkpoint/index.html"
    },
    {
      "src": "/mortalidade",
      "dest": "/mortalidade/index.html"
    },
    {
      "src": "/mortalidade/(.*)",
      "dest": "/mortalidade/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
